<h1>投稿詳細</h1>

<div class="row">
  <div class="col-8">
    <table class="table">
      <tbody>
        <tr>
          <th>id</th>
          <td><%= @post.id %></td>
        </tr>
        <tr>
          <th>ユーザー種別</th>
          <td><%= @post.postable_type %></td>
        </tr>
        <tr>
          <th>ユーザー名</th>
          <td><%= link_to @post.postable.name, polymorphic_path([:admin, @post.postable ]) %></td>
        </tr>
        <tr>
          <th>タイトル</th>
          <td><%= @post.title %></td>
        </tr>
        <tr>
          <th>内容</th>
          <td><%= @post.body %></td>
        </tr>
        <tr>
          <th>投稿日</th>
          <td><%= @post.created_at.strftime("%Y/%m/%d %H:%M") %></td>
        </tr>
        
      </tbody>
    </table>
    <div class="col-4 mx-auto">
      <%= link_to "投稿削除", admin_post_path(@post), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger btn-block " %>
    </div>
  </div>
  <div class="col-3 offset-1">
  </div>
  <div class="my-2">
  <%= link_to '投稿一覧へ戻る', admin_posts_path %>
  </div>
</div>