<div class="container">
  <div class="row">
    <h2 class="mt-3">新規投稿</h2>
      <%= form_with model: @post do |f| %>
        <div class="form-group">
        <label for="post_title">タイトル</label>
        <%= f.text_field :title %>
        </div>
        <div class="form-group">
        <label for="post_body">本文</label>
        <%= f.text_area :body %>
        </div>
        <div class="form-group">
        <%= f.submit '投稿する', class: 'btn btn-success' %>
        </div>
      <% end %>
  </div>
</div>
