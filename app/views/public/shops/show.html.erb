<div class='col-md-8 offset-md-1'>
<h2>あなたの投稿一覧</h2>
<% if @posts.any? %>
  <ul>
    <% @posts.each do |post| %>
      <li>
        <%= link_to post.title, post_path(post) %> 
        <small>(投稿日: <%= post.created_at.strftime("%Y/%m/%d") %>)</small>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだ投稿がありません。</p>
<% end %>
</div>