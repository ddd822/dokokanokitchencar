<div class="row">
  <div class='col-md-4'>
    <h2>プロフィール</h2>
      <table class='table'>
      <tr>
        <th>店舗名</th>
        <td><%= @shop.name %></td>
      </tr>
      <tr>
	      <th>メールアドレス</th>
	      <td><%= @shop.email %></td>
      </tr>
      <tr>
        <th>電話番号</th>
        <td><%= @shop.telephone_number.presence || "未設定" %></td>
      </tr>
      <tr>
        <th>定休日</th>
        <td>
          <% if @shop.weekdays.any? %>
            <%= @shop.weekdays.pluck(:name).join(", ") %>
          <% else %>
            未設定
          <% end %>
        </td>
      </tr>
      <tr>
        <th>店舗紹介</th>
        <td><%= @shop.introduction.presence || "未設定" %></td>
      </tr>
    </table>
    <% if shop_signed_in? && @shop == current_shop %>
    <div class='my-3'>
      <%= link_to 'プロフィールを編集する', edit_shop_path(@shop), class: "btn btn-sm btn-success" %>
    </div>
      <div class='my-3'>
        <%= link_to '退会する', shop_path(@shop), method: :delete, data: { confirm: '本当に退会しますか？' }, class: "btn btn-sm btn-danger" %>
      </div>
    <% end %>
  </div>
  <div class='col-md-4'>
    <h2>あなたの投稿一覧</h2>
    <% if @posts.any? %>
      <ul>
        <% @posts.each do |post| %>
          <li>
            <%= link_to post.title, post_path(post) %> 
            <small>(投稿日: <%= post.created_at.strftime("%Y/%m/%d") %>)</small>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>まだ投稿がありません。</p>
    <% end %>
  </div>
  <div class='col-md-4'>  
    <h2>あなたのコメント一覧</h2>
    <% if @comments.any? %>
      <ul>
        <% @comments.each do |comment| %>
          <div class='mb-2'>
            <li>
              <%= simple_format(comment.body) %>
              <small>(コメント日時: <%= comment.created_at.strftime("%Y/%m/%d %H:%M") %>)</small><br>
              <small>(対象投稿タイトル:
              <% if comment.commentable.present? %>
                <%= link_to comment.commentable.title, post_path(comment.commentable) %>)
              <% else %>
                (投稿が削除されています)
              <% end %></small>
            </li>
          </div>
        <% end %>      
      </ul>
    <% else %>
      <p>コメントはまだありません。</p>
    <% end %>
  </div>
</div>