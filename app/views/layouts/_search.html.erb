<% if admin_signed_in? %>
  <%= form_with url: search_admin_posts_path, method: :get, class: "form-inline my-2 my-lg-0" do |form| %>
    <%= form.text_field :keyword, value: params[:keyword], placeholder: "жҠ•зЁҝгӮ’жӨңзҙў", class: "form-control mr-sm-2" %>
    <%= form.submit "жӨңзҙў", class: "btn btn-warning my-2 my-sm-0" %>
  <% end %>
<% else %>
  <%= form_with url: search_posts_path, method: :get, html: { class: "form-inline my-2 my-lg-0" } do |form| %>
    <%= form.text_field :keyword, value: params[:keyword], placeholder: "гӮӯгғјгғҜгғјгғүгҒ§жҠ•зЁҝгӮ’жӨңзҙў", class: "form-control mr-sm-2" %>
    <%= form.submit "жӨңзҙў", class: "btn btn-warning my-2 my-sm-0" %>
  <% end %>
<% end %>