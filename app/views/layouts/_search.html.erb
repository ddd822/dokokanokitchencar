<%= form_with url: search_posts_path, method: :get, html: { class: "form-inline my-2 my-lg-0" } do |form| %>
  <%= form.text_field :keyword, value: params[:keyword], placeholder: "キーワードで投稿を検索", class: "form-control mr-sm-2" %>
  <%= form.submit "検索", class: "btn btn-warning my-2 my-sm-0" %>
<% end %>