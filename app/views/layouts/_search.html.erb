<%= form_with url: search_posts_path, method: :get, html: { class: "form-inline my-2 my-lg-0" } do |form| %>
  <%= form.text_field :keyword, value: params[:keyword], placeholder: "гӮӯгғјгғҜгғјгғүгҒ§жҠ•зЁҝгӮ’жӨңзҙў", class: "form-control form-control-sm mr-sm-2" %>
  <%= form.select :tag_id, options_from_collection_for_select(@tags, :id, :name, params[:tag_id]),
                  { include_blank: 'гӮҝгӮ°гҒ§зөһгӮҠиҫјгҒҝ' }, class: "form-control form-control-sm mr-sm-2" %>
  <%= form.submit "жӨңзҙў", class: "btn btn-sm btn-warning my-2 my-sm-0" %>
<% end %>