  </head>

  <body>
  <header>
    <%= render 'layouts/customer_navigation' %>
  </header>
  <div class="container">
    <%= render 'layouts/flash_messages' %>
    <%= yield %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/jquery-jpostal-ja@2.14.45/jquery.jpostal.min.js"></script>
  </body>
</html>
