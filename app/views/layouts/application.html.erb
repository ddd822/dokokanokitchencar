<!DOCTYPE html>
<html>
  <head>
    <title>Dokokanokitchencar</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  <header>
    <% if customer_signed_in? %>
      <li>
        <%= link_to "HOME", root_path %>
      </li>
      <li>
        <%= link_to "ABOUT", about_path %>
      </li>
      <li>
        <%= link_to "ログアウト", destroy_customer_session_path, method: :delete %>
      </li>
    <% else %>
      <li>
        <%= link_to "HOME", root_path %>
      </li>
      <li>
        <%= link_to "ABOUT", about_path %>
      </li>
      <li>
        <%= link_to "一般会員新規登録", new_customer_registration_path %>
      </li>
      <li>
        <%= link_to "一般会員ログイン", new_customer_session_path %>
      </li>
      <li>
        <%= link_to "店舗会員新規登録", new_shop_registration_path %>
      </li>
      <li>
        <%= link_to "店舗会員ログイン", new_shop_session_path %>
      </li>
    <% end %>
  </header>
  <div class="container">
    <%= notice %>
    <%= alert %>  
    <%= yield %>
  </div>
  </body>
</html>
